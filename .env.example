# Renomeie este arquivo para .env e preencha com os dados do seu projeto Supabase
# (Project Settings -> API Keys). Use a PUBLISHABLE key (novo padrão).
# Atenção: o prefixo precisa ser VITE_ (este projeto usa Vite, não Next.js).
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx
